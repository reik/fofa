{
  "expo": {
    "name": "FoFa",
    "slug": "fofa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#e8f5ec"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fofa.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#e8f5ec"
      },
      "package": "com.fofa.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "FoFa needs access to your photos to set profile pictures."
        }
      ]
    ]
  }
}
